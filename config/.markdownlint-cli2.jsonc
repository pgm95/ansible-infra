{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/v0.20.0/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "default": true,
    "MD013": false,
    "MD040": false,
    "MD060": false,
    "MD024": false
  },
  "ignores": [
    ".ansible",
    ".archive",
    ".claude",
    ".cache",
    ".old",
    ".tmp"
  ]
}
