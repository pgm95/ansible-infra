{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://homeops.local/schemas/common.schema.json",
  "title": "Common Definitions",
  "description": "Shared definitions for Proxmox guest validation",

  "$defs": {
    "patterns": {
      "hostname": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]{0,62}$",
        "description": "RFC 1123 hostname (lowercase, starts with letter, alphanumeric and hyphens only)"
      },
      "vmid": {
        "type": "string",
        "pattern": "^[1-9][0-9]{1,8}$",
        "description": "Proxmox VMID (100-999999999 as string)"
      },
      "bridge": {
        "type": "string",
        "pattern": "^vmbr[0-9]+$",
        "description": "Proxmox network bridge (vmbr0, vmbr1, etc.)"
      },
      "vlan": {
        "type": "string",
        "pattern": "^([1-9][0-9]{0,2}|[1-3][0-9]{3}|40[0-8][0-9]|409[0-4])?$",
        "description": "VLAN tag (1-4094) or empty for untagged"
      },
      "mac": {
        "type": "string",
        "pattern": "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$|^$",
        "description": "MAC address (XX:XX:XX:XX:XX:XX) or empty for auto-generate"
      },
      "ipv4_cidr": {
        "type": "string",
        "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)/([0-9]|[1-2][0-9]|3[0-2])$",
        "description": "IPv4 address in CIDR notation (e.g., 192.168.1.100/24)"
      },
      "ipv4_address": {
        "type": "string",
        "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$",
        "description": "IPv4 address without CIDR (e.g., 192.168.1.1)"
      },
      "bind_mount": {
        "type": "string",
        "pattern": "^/.+:/.+$",
        "description": "Bind mount format: /host/path:/container/path"
      },
      "tags": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9;_-]*$",
        "description": "Semicolon-separated tags (e.g., ansible;test;production)"
      },
      "uid_gid": {
        "type": "string",
        "pattern": "^[0-9]*$",
        "description": "UID or GID as string (e.g., '1000') or empty to disable"
      }
    },

    "enums": {
      "ipv4_method": {
        "type": "string",
        "enum": ["auto", "dhcp", "static", "none"],
        "description": "IPv4 configuration method"
      },
      "ipv6_method": {
        "type": "string",
        "enum": ["auto", "dhcp", "static", "none", ""],
        "description": "IPv6 configuration method (empty to omit)"
      },
      "debian_version": {
        "type": "string",
        "enum": ["11", "12", "13"],
        "description": "Debian version: 11=Bullseye, 12=Bookworm, 13=Trixie"
      }
    },

    "ranges": {
      "cores": {
        "type": "integer",
        "minimum": 1,
        "maximum": 128,
        "description": "CPU cores (1-128)"
      },
      "memory_mb": {
        "type": "integer",
        "minimum": 128,
        "maximum": 524288,
        "description": "Memory in MiB (128-524288)"
      },
      "disk_gb": {
        "type": "integer",
        "minimum": 1,
        "maximum": 999999,
        "description": "Disk size in GiB (1-999999)"
      },
      "startup_order": {
        "type": "integer",
        "minimum": 0,
        "maximum": 999,
        "description": "Boot priority (0=any order, 1-999=ordered)"
      }
    },

    "application": {
      "docker_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable Docker installation"
      },
      "docker_data_root": {
        "type": "string",
        "default": "/var/lib/docker",
        "description": "Docker root data directory"
      },
      "docker_storage_driver": {
        "type": "string",
        "default": "",
        "description": "Storage driver: overlay2, btrfs, zfs, etc (empty = auto)"
      },
      "docker_mtu": {
        "type": "integer",
        "default": 0,
        "minimum": 0,
        "maximum": 65535,
        "description": "Default MTU for networks (0 = auto, 1400 recommended for tunneled traffic)"
      },
      "docker_bridge_ip": {
        "type": "string",
        "default": "",
        "description": "Custom docker0 bridge IP in CIDR (e.g., 172.17.0.1/16)"
      },
      "docker_default_address_pools": {
        "type": "array",
        "default": [],
        "description": "Default address pools for bridge networks",
        "items": {
          "type": "object",
          "properties": {
            "base": { "type": "string" },
            "size": { "type": "integer" }
          }
        }
      },
      "docker_dns_servers": {
        "type": "array",
        "default": [],
        "description": "DNS servers for containers",
        "items": { "type": "string" }
      },
      "docker_dns_search": {
        "type": "array",
        "default": [],
        "description": "DNS search domains",
        "items": { "type": "string" }
      },
      "docker_dns_options": {
        "type": "array",
        "default": [],
        "description": "DNS options (e.g., ndots:1)",
        "items": { "type": "string" }
      },
      "docker_iptables_enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable iptables rules for container networking"
      },
      "docker_ip_forward": {
        "type": "boolean",
        "default": true,
        "description": "Enable IP forwarding"
      },
      "docker_ipv6_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable IPv6 networking"
      },
      "docker_fixed_cidr_v6": {
        "type": "string",
        "default": "",
        "description": "IPv6 subnet for containers"
      },
      "docker_log_driver": {
        "type": "string",
        "default": "json-file",
        "description": "Logging driver: json-file, journald, syslog, etc"
      },
      "docker_log_max_size": {
        "type": "string",
        "default": "50m",
        "description": "Maximum log file size before rotation"
      },
      "docker_log_max_file": {
        "type": "string",
        "default": "3",
        "description": "Maximum number of log files to retain"
      },
      "docker_log_compress": {
        "type": "boolean",
        "default": false,
        "description": "Compress rotated log files"
      },
      "docker_live_restore": {
        "type": "boolean",
        "default": true,
        "description": "Keep containers running during daemon downtime"
      },
      "docker_userland_proxy": {
        "type": "boolean",
        "default": true,
        "description": "Use userland proxy for loopback traffic"
      },
      "docker_registry_mirrors": {
        "type": "array",
        "default": [],
        "description": "Registry mirrors",
        "items": { "type": "string", "format": "uri" }
      },
      "docker_insecure_registries": {
        "type": "array",
        "default": [],
        "description": "Insecure registries",
        "items": { "type": "string" }
      },
      "docker_metrics_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable Prometheus metrics endpoint"
      },
      "docker_metrics_addr": {
        "type": "string",
        "default": "127.0.0.1:9323",
        "description": "Metrics endpoint address"
      },
      "docker_experimental": {
        "type": "boolean",
        "default": false,
        "description": "Enable experimental features"
      },
      "docker_swarm_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable Docker Swarm mode (requires docker_enabled)"
      },
      "docker_swarm_role": {
        "type": "string",
        "enum": ["manager", "worker"],
        "default": "worker",
        "description": "Swarm node role: manager (control plane) or worker (workloads only)"
      },
      "docker_swarm_init": {
        "type": "boolean",
        "default": false,
        "description": "Initialize new swarm cluster (true ONLY on first manager)"
      },
      "docker_swarm_advertise_addr": {
        "type": "string",
        "default": "",
        "description": "Advertise address for swarm traffic (empty for auto-detect)"
      },
      "docker_swarm_listen_addr": {
        "type": "string",
        "default": "0.0.0.0:2377",
        "description": "Listen address for swarm management traffic"
      },
      "docker_swarm_data_path_addr": {
        "type": "string",
        "default": "",
        "description": "Address/interface for overlay data traffic (empty = auto)"
      },
      "docker_swarm_data_path_port": {
        "type": "integer",
        "default": 4789,
        "minimum": 1,
        "maximum": 65535,
        "description": "UDP port for VXLAN overlay network traffic"
      },
      "docker_swarm_default_addr_pool": {
        "type": "array",
        "default": [],
        "description": "Default address pools for overlay networks (e.g., [\"10.10.0.0/16\"])",
        "items": {
          "type": "string"
        }
      },
      "docker_swarm_subnet_size": {
        "type": "integer",
        "default": 24,
        "minimum": 1,
        "maximum": 29,
        "description": "Default subnet size for overlay networks"
      },
      "docker_swarm_autolock": {
        "type": "boolean",
        "default": false,
        "description": "Encrypt Raft logs at rest (requires unlock on restart)"
      },
      "docker_swarm_election_tick": {
        "type": "integer",
        "default": 10,
        "minimum": 1,
        "description": "Raft election timeout in ticks (role default: 10, swarm group_vars overrides to 30 for WAN/Tailscale)"
      },
      "docker_swarm_heartbeat_tick": {
        "type": "integer",
        "default": 1,
        "minimum": 1,
        "description": "Raft heartbeat interval in ticks (role default: 1, swarm group_vars overrides to 3 for WAN/Tailscale)"
      },
      "docker_swarm_cert_expiry": {
        "type": "string",
        "default": "",
        "description": "Node certificate expiry (e.g., 2160h for 90 days)"
      },
      "docker_swarm_vxlan_interface": {
        "type": "string",
        "default": "",
        "description": "Interface to restrict VXLAN traffic to (e.g., tailscale0). Creates iptables rule to drop port 4789/UDP on other interfaces. Use for nodes with public IPs."
      },
      "docker_swarm_labels": {
        "type": "object",
        "default": {},
        "description": "Node labels for placement constraints (e.g., {\"zone\": \"dmz\"})",
        "additionalProperties": {
          "type": "string"
        }
      },
      "docker_swarm_availability": {
        "type": "string",
        "enum": ["active", "pause", "drain"],
        "default": "active",
        "description": "Node availability: active (accept tasks), pause (no new tasks), drain (evacuate)"
      },
      "docker_swarm_manager_token": {
        "type": "string",
        "default": "",
        "description": "Manager join token (from vault or leave empty for runtime discovery)"
      },
      "docker_swarm_worker_token": {
        "type": "string",
        "default": "",
        "description": "Worker join token (from vault or leave empty for runtime discovery)"
      },
      "docker_swarm_manager_addrs": {
        "type": "array",
        "default": [],
        "description": "Manager addresses for joining (e.g., [\"192.168.1.10:2377\"])",
        "items": {
          "type": "string",
          "pattern": "^.+:[0-9]+$"
        }
      },
      "tailscale_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable Tailscale VPN"
      },
      "samba_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable Samba fileserver"
      },
      "samba_existing_user": {
        "type": "string",
        "description": "Existing system user for Samba access"
      },
      "samba_password": {
        "type": "string",
        "description": "Samba password (use vault reference)"
      },
      "dotfiles_enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable dotfiles deployment"
      },
      "dotfiles_deploy_to_root": {
        "type": "boolean",
        "default": false,
        "description": "Deploy dotfiles to root user"
      },
      "packages_install_shell": {
        "type": "boolean",
        "default": false,
        "description": "Install shell utilities (zsh, tmux, etc.)"
      },
      "packages_install_network": {
        "type": "boolean",
        "default": false,
        "description": "Install network utilities (curl, wget, etc.)"
      }
    },

    "users": {
      "users_list": {
        "type": "array",
        "description": "List of users to create",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "pattern": "^[a-z_][a-z0-9_-]*$",
              "description": "Username (lowercase, starts with letter or underscore)"
            },
            "uid": {
              "type": "integer",
              "minimum": 1000,
              "maximum": 65534,
              "description": "User ID"
            },
            "gid": {
              "type": "integer",
              "minimum": 1000,
              "maximum": 65534,
              "description": "Primary group ID"
            },
            "group": {
              "type": "string",
              "description": "Primary group name"
            },
            "shell": {
              "type": "string",
              "description": "Login shell path"
            },
            "home": {
              "type": "string",
              "description": "Home directory path"
            },
            "create_home": {
              "type": "boolean",
              "default": true,
              "description": "Create home directory"
            }
          },
          "required": ["name"]
        }
      }
    }
  }
}
