{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://homeops.local/schemas/lxc.schema.json",
  "title": "LXC Container Configuration",
  "description": "Schema for lxc variables - Validates LXC container definitions",
  "type": "object",

  "required": ["pve_host", "lxc_vmid", "lxc_hostname"],

  "properties": {
    "pve_host": {
      "type": "string",
      "pattern": "^pve[0-9]+$",
      "description": "Target Proxmox host (REQUIRED) - credentials inherited from group_vars/proxmox.yml"
    },
    "lxc_vmid": {
      "type": "string",
      "pattern": "^[1-9][0-9]{1,8}$",
      "description": "Container VMID (100-999999999) - REQUIRED for ansible_id reconciliation"
    },
    "lxc_hostname": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,62}$",
      "description": "Container hostname (RFC 1123) - REQUIRED for ansible_id reconciliation"
    },
    "lxc_description": {
      "type": "string",
      "description": "Container description shown in Proxmox UI"
    },
    "lxc_tags": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9;_-]*$",
      "description": "Semicolon-separated tags (e.g., 'ansible;test;production')"
    },
    "lxc_privileged": {
      "type": "boolean",
      "default": false,
      "description": "Run as privileged container (not recommended for security)"
    },
    "lxc_os_version": {
      "type": "string",
      "enum": ["11", "12", "13"],
      "description": "Debian version: 11=Bullseye, 12=Bookworm, 13=Trixie"
    },
    "lxc_start_on_boot": {
      "type": "boolean",
      "default": false,
      "description": "Start container when Proxmox host boots"
    },
    "lxc_startup_order": {
      "type": "integer",
      "minimum": 0,
      "maximum": 999,
      "default": 0,
      "description": "Boot priority (0=any order, 1-999=ordered, lower starts first)"
    },

    "lxc_cores": {
      "type": "integer",
      "minimum": 1,
      "maximum": 128,
      "default": 2,
      "description": "Number of CPU cores"
    },
    "lxc_memory": {
      "type": "integer",
      "minimum": 128,
      "maximum": 524288,
      "default": 1024,
      "description": "RAM in MiB"
    },
    "lxc_swap": {
      "type": "integer",
      "minimum": 0,
      "maximum": 524288,
      "default": 1024,
      "description": "Swap in MiB (0 to disable)"
    },
    "lxc_default_storage": {
      "type": "string",
      "default": "",
      "description": "Default storage pool for all disks (empty for auto-select)"
    },
    "lxc_disks": {
      "type": "array",
      "minItems": 1,
      "description": "Disk configuration array. First disk (index 0) is rootfs, additional disks become mount points (mp0, mp1, ...)",
      "items": {
        "type": "object",
        "required": ["size"],
        "properties": {
          "size": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999999,
            "description": "Disk size in GiB"
          },
          "mp": {
            "type": "string",
            "pattern": "^/.*$",
            "description": "Mount point path (implicit '/' for rootfs, REQUIRED for additional disks)"
          },
          "storage": {
            "type": "string",
            "description": "Storage pool (inherits from lxc_default_storage if empty)"
          },
          "backup": {
            "type": "boolean",
            "default": true,
            "description": "Include disk in Proxmox backups"
          },
          "acl": {
            "type": "boolean",
            "default": false,
            "description": "ACL support (useful for Samba)"
          },
          "quota": {
            "type": "boolean",
            "default": false,
            "description": "Enable disk quota"
          },
          "replicate": {
            "type": "boolean",
            "default": true,
            "description": "Replication support"
          },
          "ro": {
            "type": "boolean",
            "default": false,
            "description": "Read-only mount"
          }
        }
      }
    },

    "lxc_net_bridge": {
      "type": "string",
      "pattern": "^vmbr[0-9]+$",
      "default": "vmbr0",
      "description": "Proxmox network bridge"
    },
    "lxc_net_ipv4_method": {
      "type": "string",
      "enum": ["auto", "dhcp", "static", "none"],
      "default": "auto",
      "description": "IPv4 configuration method"
    },
    "lxc_net_ipv4_static": {
      "type": "string",
      "description": "Static IPv4 in CIDR notation (required if method=static)"
    },
    "lxc_net_ipv4_gateway": {
      "type": "string",
      "description": "IPv4 gateway address (required if method=static)"
    },
    "lxc_net_ipv6_method": {
      "type": "string",
      "enum": ["auto", "dhcp", "static", "none", ""],
      "default": "",
      "description": "IPv6 configuration method (empty to omit)"
    },
    "lxc_net_ipv6_static": {
      "type": "string",
      "description": "Static IPv6 in CIDR notation (required if method=static)"
    },
    "lxc_net_ipv6_gateway": {
      "type": "string",
      "description": "IPv6 gateway address (required if method=static)"
    },
    "lxc_net_vlan": {
      "type": "string",
      "pattern": "^([1-9][0-9]{0,2}|[1-3][0-9]{3}|40[0-8][0-9]|409[0-4])?$",
      "default": "",
      "description": "VLAN tag (1-4094) or empty for untagged"
    },
    "lxc_net_mac": {
      "type": "string",
      "pattern": "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$|^$",
      "default": "",
      "description": "MAC address or empty for auto-generate"
    },
    "lxc_net_mtu": {
      "type": "string",
      "default": "",
      "description": "MTU size (empty for bridge default 1500)"
    },
    "lxc_net_nameserver": {
      "type": "string",
      "default": "",
      "description": "DNS server IP (empty to use host's resolver)"
    },
    "lxc_net_search_domain": {
      "type": "string",
      "default": "",
      "description": "DNS search domain (empty to use host's)"
    },
    "lxc_net_apt_cacher_ip": {
      "type": "string",
      "default": "",
      "description": "Apt-cacher-ng proxy server IP"
    },

    "lxc_root_password": {
      "type": "string",
      "description": "Root password (use vault reference like {{ vault_lxc_root_pass }})"
    },
    "lxc_feature_fuse": {
      "type": "boolean",
      "default": false,
      "description": "Enable FUSE support (rclone, mergerfs, AppImage)"
    },
    "lxc_feature_mknod": {
      "type": "boolean",
      "default": false,
      "description": "Enable device node creation capability"
    },
    "lxc_feature_nesting": {
      "type": "boolean",
      "default": false,
      "description": "Enable nested virtualization (required for Docker)"
    },
    "lxc_feature_keyctl": {
      "type": "boolean",
      "default": false,
      "description": "Enable keyring support (unprivileged containers only)"
    },
    "lxc_feature_nfs": {
      "type": "boolean",
      "default": false,
      "description": "Enable NFS mounts (privileged containers only)"
    },
    "lxc_feature_cifs": {
      "type": "boolean",
      "default": false,
      "description": "Enable CIFS/SMB mounts (privileged containers only)"
    },

    "lxc_device_tun": {
      "type": "boolean",
      "default": false,
      "description": "Enable TUN device for VPN (Tailscale, WireGuard)"
    },
    "lxc_device_vaapi": {
      "type": "boolean",
      "default": false,
      "description": "Enable GPU video encode/decode passthrough"
    },
    "lxc_device_framebuffer": {
      "type": "boolean",
      "default": false,
      "description": "Enable framebuffer device passthrough"
    },
    "lxc_device_kfd": {
      "type": "boolean",
      "default": false,
      "description": "Enable AMD GPU compute (ROCm) passthrough"
    },
    "lxc_device_usb_serial": {
      "type": "boolean",
      "default": false,
      "description": "Enable USB serial devices (/dev/ttyUSB*)"
    },
    "lxc_device_usb_acm": {
      "type": "boolean",
      "default": false,
      "description": "Enable USB ACM devices (/dev/ttyACM*)"
    },

    "lxc_idmap_uid": {
      "type": "string",
      "pattern": "^[0-9]*$",
      "default": "",
      "description": "UID for 1:1 mapping in unprivileged container (e.g., '1000')"
    },
    "lxc_idmap_gid": {
      "type": "string",
      "pattern": "^[0-9]*$",
      "default": "",
      "description": "GID for 1:1 mapping in unprivileged container (e.g., '1000')"
    },
    "lxc_idmap_gid_match_devices": {
      "type": "boolean",
      "default": false,
      "description": "Use mapped GID for hardware device permissions"
    },

    "lxc_bind_mounts": {
      "type": "array",
      "default": [],
      "description": "List of bind mounts in 'host:container' format",
      "items": {
        "type": "string",
        "pattern": "^/.+:/.+$",
        "description": "Bind mount: /host/path:/container/path"
      }
    },

    "lxc_console_dev_enable": {
      "type": "boolean",
      "default": false,
      "description": "Attach /dev/console device to container"
    },
    "lxc_console_tty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 6,
      "default": 0,
      "description": "Number of TTY devices (0-6)"
    },
    "lxc_console_mode": {
      "type": "string",
      "enum": ["shell", "console", "tty"],
      "default": "shell",
      "description": "Console access mode"
    },

    "lxc_start_after_create": {
      "type": "boolean",
      "default": true,
      "description": "Start container immediately after creation"
    },
    "lxc_wait_for_network": {
      "type": "boolean",
      "default": true,
      "description": "Wait for network to be ready before provisioning"
    },

    "docker_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Install Docker (requires lxc_feature_nesting: true)"
    },
    "docker_data_root": {
      "type": "string",
      "default": "/var/lib/docker",
      "description": "Docker root data directory"
    },
    "docker_storage_driver": {
      "type": "string",
      "default": "",
      "description": "Storage driver: overlay2, btrfs, zfs, etc (empty = auto)"
    },
    "docker_mtu": {
      "type": "integer",
      "default": 0,
      "minimum": 0,
      "maximum": 65535,
      "description": "Default MTU for networks (0 = auto, 1400 for tunneled traffic)"
    },
    "docker_bridge_ip": {
      "type": "string",
      "default": "",
      "description": "Custom docker0 bridge IP in CIDR"
    },
    "docker_dns_servers": {
      "type": "array",
      "default": [],
      "description": "DNS servers for containers",
      "items": { "type": "string" }
    },
    "docker_dns_search": {
      "type": "array",
      "default": [],
      "description": "DNS search domains",
      "items": { "type": "string" }
    },
    "docker_log_driver": {
      "type": "string",
      "default": "json-file",
      "description": "Logging driver: json-file, journald, syslog, etc"
    },
    "docker_log_max_size": {
      "type": "string",
      "default": "50m",
      "description": "Maximum log file size before rotation"
    },
    "docker_log_max_file": {
      "type": "string",
      "default": "3",
      "description": "Maximum number of log files to retain"
    },
    "docker_live_restore": {
      "type": "boolean",
      "default": true,
      "description": "Keep containers running during daemon downtime"
    },
    "docker_registry_mirrors": {
      "type": "array",
      "default": [],
      "description": "Registry mirrors",
      "items": { "type": "string" }
    },
    "docker_insecure_registries": {
      "type": "array",
      "default": [],
      "description": "Insecure registries",
      "items": { "type": "string" }
    },
    "docker_metrics_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable Prometheus metrics endpoint"
    },
    "docker_metrics_addr": {
      "type": "string",
      "default": "127.0.0.1:9323",
      "description": "Metrics endpoint address"
    },
    "docker_gpu_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Deploy DRM udev rules and auto-register gpu=1 generic resource for Swarm scheduling"
    },
    "docker_node_generic_resources": {
      "type": "array",
      "default": [],
      "description": "Non-GPU generic resources for Swarm scheduling. For GPU, use docker_gpu_enabled",
      "items": { "type": "string" }
    },
    "docker_swarm_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Enable Docker Swarm mode (requires docker_enabled)"
    },
    "docker_swarm_role": {
      "type": "string",
      "enum": ["manager", "worker"],
      "default": "worker",
      "description": "Swarm node role: manager (control plane) or worker (workloads only)"
    },
    "docker_swarm_init": {
      "type": "boolean",
      "default": false,
      "description": "Initialize new swarm cluster (true ONLY on first manager)"
    },
    "docker_swarm_advertise_addr": {
      "type": "string",
      "default": "",
      "description": "Advertise address for swarm traffic (empty for auto-detect)"
    },
    "docker_swarm_listen_addr": {
      "type": "string",
      "default": "0.0.0.0:2377",
      "description": "Listen address for swarm management traffic"
    },
    "docker_swarm_data_path_addr": {
      "type": "string",
      "default": "",
      "description": "Address/interface for overlay data traffic"
    },
    "docker_swarm_data_path_port": {
      "type": "integer",
      "default": 4789,
      "minimum": 1,
      "maximum": 65535,
      "description": "UDP port for VXLAN overlay network traffic"
    },
    "docker_swarm_default_addr_pool": {
      "type": "array",
      "default": [],
      "description": "Default address pools for overlay networks (e.g., [\"10.10.0.0/16\"])",
      "items": {
        "type": "string"
      }
    },
    "docker_swarm_subnet_size": {
      "type": "integer",
      "default": 24,
      "minimum": 1,
      "maximum": 29,
      "description": "Default subnet size for overlay networks"
    },
    "docker_swarm_autolock": {
      "type": "boolean",
      "default": false,
      "description": "Encrypt Raft logs at rest"
    },
    "docker_swarm_election_tick": {
      "type": "integer",
      "default": 10,
      "minimum": 1,
      "description": "Raft election timeout in ticks (role default: 10, swarm group_vars overrides to 30 for WAN/Tailscale)"
    },
    "docker_swarm_heartbeat_tick": {
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "description": "Raft heartbeat interval in ticks (role default: 1, swarm group_vars overrides to 3 for WAN/Tailscale)"
    },
    "docker_swarm_cert_expiry": {
      "type": "string",
      "default": "",
      "description": "Node certificate expiry (e.g., 2160h)"
    },
    "docker_swarm_labels": {
      "type": "object",
      "default": {},
      "description": "Node labels for placement constraints",
      "additionalProperties": {
        "type": "string"
      }
    },
    "docker_swarm_availability": {
      "type": "string",
      "enum": ["active", "pause", "drain"],
      "default": "active",
      "description": "Node availability: active, pause, or drain"
    },
    "docker_swarm_manager_token": {
      "type": "string",
      "default": "",
      "description": "Manager join token (from vault or runtime discovery)"
    },
    "docker_swarm_worker_token": {
      "type": "string",
      "default": "",
      "description": "Worker join token (from vault or runtime discovery)"
    },
    "docker_swarm_manager_addrs": {
      "type": "array",
      "default": [],
      "description": "Manager addresses for joining (e.g., [\"192.168.1.10:2377\"])",
      "items": {
        "type": "string",
        "pattern": "^.+:[0-9]+$"
      }
    },
    "tailscale_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Install Tailscale VPN (requires lxc_device_tun: true)"
    },
    "tailscale_tags": {
      "type": "array",
      "default": [],
      "description": "Tailscale ACL tags (e.g., [\"server\", \"swarm\"])",
      "items": { "type": "string" }
    },
    "tailscale_ip": {
      "type": "string",
      "default": "",
      "description": "Expected Tailscale IP address (100.x.x.x)"
    },
    "tailscale_bind_ssh": {
      "type": "boolean",
      "default": false,
      "description": "Bind SSH to Tailscale interface only"
    },
    "samba_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Install and configure Samba fileserver"
    },
    "samba_existing_user": {
      "type": "string",
      "description": "Existing system user for Samba access"
    },
    "samba_password": {
      "type": "string",
      "description": "Samba password (use vault reference)"
    },
    "dotfiles_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Deploy dotfiles from GitHub repository"
    },
    "dotfiles_deploy_to_root": {
      "type": "boolean",
      "default": false,
      "description": "Deploy dotfiles to root user's home"
    },
    "dotfiles_deploy_args": {
      "type": "string",
      "default": "",
      "description": "Arguments passed verbatim to deploy.sh (e.g. 'bash nano claude')"
    },
    "packages_install_shell": {
      "type": "boolean",
      "default": false,
      "description": "Install shell utilities (zsh, tmux, fzf, etc.)"
    },
    "packages_install_network": {
      "type": "boolean",
      "default": false,
      "description": "Install network utilities (curl, wget, dig, etc.)"
    },

    "users_list": {
      "type": "array",
      "description": "List of system users to create",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_-]*$",
            "description": "Username"
          },
          "uid": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 65534,
            "description": "User ID"
          },
          "gid": {
            "type": "integer",
            "minimum": 1000,
            "maximum": 65534,
            "description": "Primary group ID"
          },
          "group": {
            "type": "string",
            "description": "Primary group name"
          },
          "shell": {
            "type": "string",
            "description": "Login shell"
          },
          "home": {
            "type": "string",
            "description": "Home directory path"
          },
          "create_home": {
            "type": "boolean",
            "default": true,
            "description": "Create home directory"
          }
        },
        "required": ["name"]
      }
    }
  },

  "allOf": [
    {
      "if": {
        "properties": {
          "lxc_net_ipv4_method": { "const": "static" }
        },
        "required": ["lxc_net_ipv4_method"]
      },
      "then": {
        "required": ["lxc_net_ipv4_static", "lxc_net_ipv4_gateway"]
      }
    },
    {
      "if": {
        "properties": {
          "lxc_net_ipv6_method": { "const": "static" }
        },
        "required": ["lxc_net_ipv6_method"]
      },
      "then": {
        "required": ["lxc_net_ipv6_static", "lxc_net_ipv6_gateway"]
      }
    },
    {
      "if": {
        "properties": {
          "lxc_idmap_uid": {
            "type": "string",
            "pattern": "^[0-9]+$"
          }
        },
        "required": ["lxc_idmap_uid"]
      },
      "then": {
        "properties": {
          "lxc_privileged": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lxc_idmap_gid": {
            "type": "string",
            "pattern": "^[0-9]+$"
          }
        },
        "required": ["lxc_idmap_gid"]
      },
      "then": {
        "properties": {
          "lxc_privileged": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "samba_enabled": { "const": true }
        },
        "required": ["samba_enabled"]
      },
      "then": {
        "required": ["samba_existing_user", "samba_password"]
      }
    },
    {
      "if": {
        "properties": {
          "lxc_feature_nfs": { "const": true }
        },
        "required": ["lxc_feature_nfs"]
      },
      "then": {
        "properties": {
          "lxc_privileged": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lxc_feature_cifs": { "const": true }
        },
        "required": ["lxc_feature_cifs"]
      },
      "then": {
        "properties": {
          "lxc_privileged": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": {
          "docker_gpu_enabled": { "const": true }
        },
        "required": ["docker_gpu_enabled"]
      },
      "then": {
        "properties": {
          "docker_enabled": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": {
          "docker_swarm_enabled": { "const": true }
        },
        "required": ["docker_swarm_enabled"]
      },
      "then": {
        "properties": {
          "docker_enabled": { "const": true },
          "lxc_feature_nesting": { "const": true }
        }
      }
    },
    {
      "if": {
        "properties": {
          "docker_swarm_init": { "const": true }
        },
        "required": ["docker_swarm_init"]
      },
      "then": {
        "properties": {
          "docker_swarm_role": { "const": "manager" }
        }
      }
    }
  ],

  "additionalProperties": false
}
