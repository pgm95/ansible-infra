{
  // YAML Schema Associations
  "yaml.schemas": {
    "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json#/$defs/playbook": [
      // ansible playbooks
      "playbooks/*.yml"
    ],
    "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/ansible.json#/$defs/tasks": [
      // ansible tasks
      "**/tasks/*.yml"
    ],
    "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/vars.json": [
      // ansible vars
      "inventory/*/*/*.yml",
      "**/defaults/*.yml"
    ],
    "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/inventory.json": [
      // ansible inventory files
      "**/hosts.yml",
      "**/inventory.yml"
    ],
    "https://raw.githubusercontent.com/ansible/ansible-lint/main/src/ansiblelint/schemas/meta.json": [
      // ansible meta files
      "**/meta/*.yml"
    ]
  },
  // Editor Settings for YAML
  "[yaml]": {
    "editor.autoIndent": "advanced",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    },
    "editor.trimAutoWhitespace": true,
    "editor.formatOnSave": false
  },
  // Exclude patterns from explorer
  "files.exclude": {
    ".old/**": false,
    ".git/**": true,
    ".tmp/**": false,
    ".venv/**": true,
    ".vscode/**": false,
    ".archive/**": false,
    ".ansible/**": true
  },
  // Search exclusions
  "search.useIgnoreFiles": false,
  "search.exclude": {
    ".old/**": true,
    ".git/**": true,
    ".tmp/**": true,
    ".venv/**": true,
    ".vscode/**": false,
    ".archive/**": true,
    ".ansible/**": true
  },
  // Extension Settings
  "markdownlint.configFile": "config/.markdownlint-cli2.jsonc",
}
