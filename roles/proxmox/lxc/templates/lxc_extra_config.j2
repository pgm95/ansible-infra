{# ============================================================================ #}
{# LXC Extra Configuration Template                                            #}
{# ============================================================================ #}
{# Post-creation config for features unsupported by pct create.                #}
{# Currently only UID/GID mapping (lxc.idmap entries).                         #}

{# ============================================================================ #}
{# UID/GID Mapping (Unprivileged Containers Only)                              #}
{# ============================================================================ #}
{% if not lxc_privileged and lxc_idmap_uid and lxc_idmap_gid %}
lxc.idmap: u 0 100000 {{ lxc_idmap_uid }}
lxc.idmap: u {{ lxc_idmap_uid }} {{ lxc_idmap_uid }} 1
lxc.idmap: u {{ lxc_idmap_uid | int + 1 }} {{ 100000 + lxc_idmap_uid | int + 1 }} {{ 65536 - lxc_idmap_uid | int - 1 }}
lxc.idmap: g 0 100000 {{ lxc_idmap_gid }}
lxc.idmap: g {{ lxc_idmap_gid }} {{ lxc_idmap_gid }} 1
lxc.idmap: g {{ lxc_idmap_gid | int + 1 }} {{ 100000 + lxc_idmap_gid | int + 1 }} {{ 65536 - lxc_idmap_gid | int - 1 }}
{% endif %}
